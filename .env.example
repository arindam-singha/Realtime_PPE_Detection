# Roboflow API Configuration
# To use this project, copy this file to .env and fill in your actual values

ROBOFLOW_API_KEY=your_roboflow_api_key_here
ROBOFLOW_WORKSPACE=arindamsinghacomputervisionworks
ROBOFLOW_PROJECT=ppe-helmet-vest-detection-vou1p-muanm

# Optional: Model configuration
MODEL_DEVICE=0  # 0 for GPU, cpu for CPU
MODEL_EPOCHS=100
MODEL_BATCH_SIZE=16
MODEL_IMG_SIZE=(640, 480)